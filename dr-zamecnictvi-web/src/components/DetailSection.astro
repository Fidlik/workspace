---
import type { SectionBlock } from '../data/site';

type Props = {
  section: SectionBlock;
  reverse?: boolean;
};

const { section, reverse = false } = Astro.props as Props;
---

<section class:list={['detail-section', reverse && 'detail-section--reverse']} id={section.id}>
  <div class="detail-section__visuals">
    <figure class:list={['detail-section__media', 'image-card', section.plainMedia && 'image-card--plain']}>
      <img src={section.image} alt={section.title} loading="lazy" />
    </figure>

    {section.gallery && section.gallery.length > 0 && (
      <div class="detail-gallery">
        {section.gallery.map((image) => (
          <figure class:list={['detail-gallery__item', section.plainMedia && 'detail-gallery__item--plain']}>
            <img src={image.src} alt={image.alt} loading="lazy" />
          </figure>
        ))}
      </div>
    )}
  </div>

  <article class="page-card detail-section__content">
    <span class="section__eyebrow">{section.title}</span>
    <h2>{section.title}</h2>
    <p class="detail-section__lead">{section.intro}</p>
    <p>{section.text}</p>

    {section.price && (
      <div class="price-box">
        <strong>{section.price}</strong>
        {section.priceNote && <span>{section.priceNote}</span>}
      </div>
    )}

    {(section.fieldTypesTitle || section.fieldTypesText) && (
      <div class="field-types">
        {section.fieldTypesTitle && <h3>{section.fieldTypesTitle}</h3>}
        {section.fieldTypesText && <p>{section.fieldTypesText}</p>}
      </div>
    )}

    {section.variants && section.variants.length > 0 && (
      <ul class="detail-list">
        {section.variants.map((item) => <li>{item}</li>)}
      </ul>
    )}

    <div class="contact-actions">
      <a class="button button--primary" href={section.ctaHref}>
        {section.ctaLabel}
      </a>
    </div>
  </article>
</section>
