---
import Layout from '../layouts/Layout.astro';
import { company } from '../data/site';
import type { Service } from '../data/site';

type Props = {
  service: Service;
};

const { service } = Astro.props as Props;
---

<Layout title={`${service.title} | ${company.name}`} description={service.summary}>
  <section class="page-hero">
    <div class="section">
      <span class="eyebrow">{service.eyebrow}</span>
      <h1>{service.title}</h1>
      <p>{service.description}</p>
      <div class="page-meta">
        <span class="pill">Zakázková výroba</span>
        <span class="pill">Osobní přístup</span>
        <span class="pill">Studénka a okolí</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="page-grid">
      <div class="page-stack">
        <article class="page-card">
          <span class="section__eyebrow">Co je důležité</span>
          <h2>{service.detailTitle}</h2>
          <p>{service.detailIntro}</p>
          <ul class="detail-list">
            {service.detailPoints.map((item) => <li>{item}</li>)}
          </ul>
        </article>

        <article class="page-card">
          <span class="section__eyebrow">Jak pracuji</span>
          <p>
            Vše řeším osobně, od prvního telefonátu až po finální montáž. Výsledkem má být realizace, která
            dobře vypadá, dlouho vydrží a funguje bez zbytečných kompromisů.
          </p>
          <div class="contact-actions">
            <a class="button button--primary" href="/kontakty">Domluvit konzultaci</a>
            <a class="button button--ghost" href="/fotogalerie">Prohlédnout fotogalerii</a>
          </div>
        </article>
      </div>

      <div class="page-stack">
        <figure class="image-card">
          <img src={service.image} alt={service.title} loading="eager" />
        </figure>

        <article class="page-card">
          <span class="section__eyebrow">V ceně spolupráce</span>
          <ul class="detail-list">
            {service.bullets.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>
</Layout>
