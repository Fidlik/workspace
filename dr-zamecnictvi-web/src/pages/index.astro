---
import Layout from '../layouts/Layout.astro';
import { company, featuredSections, gallery, process, references, stats, strengths } from '../data/site';
---

<Layout
  title="DR zámečnictví a kovovýroba | Zakázková kovovýroba bez pluginového balastu"
  description="Moderní jednodušší prezentace pro zakázkovou kovovýrobu Daniela Richtera ve Studénce."
>
  <section class="hero">
    <div class="section hero__grid">
      <div>
        <span class="eyebrow">Zakázková kovovýroba ve Studénce</span>
        <h1>Pergoly, venkovní nábytek, oplocení a poctivé řemeslo na míru.</h1>
        <p>{company.intro}</p>

        <div class="hero__actions">
          <a class="button button--primary" href="/poptavka?produkt=obecna-poptavka">Nezávazná poptávka</a>
          <a class="button button--ghost" href="/fotogalerie">Prohlédnout realizace</a>
        </div>

        <div class="stats">
          {stats.map((item) => (
            <div class="stat">
              <strong>{item.value}</strong>
              <span>{item.label}</span>
            </div>
          ))}
        </div>
      </div>

      <figure class="hero__media">
        <img src="/images/hero.jpg" alt="Zakázková kovovýroba DR zámečnictví" loading="eager" />
        <figcaption class="hero__badge">
          <strong>{company.owner}</strong>
          <span>{company.workshop}</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="section">
    <div class="section__header">
      <span class="section__eyebrow">Hlavní sekce</span>
      <h2 class="section__title">Pět jasných vstupů místo přeplněného menu</h2>
      <p class="section__intro">
        Horní navigace je nově zjednodušená do několika hlavních sekcí. Každá z nich vede na přehlednou stránku
        a pod sebou sdružuje související oblasti výroby.
      </p>
    </div>

    <div class="service-grid">
      {featuredSections.map((service) => (
        <article class="service-card">
          <img src={service.image} alt={service.title} loading="lazy" />
          <div class="service-card__body">
            <span class="section__eyebrow">{service.eyebrow}</span>
            <h3>{service.title}</h3>
            <p>{service.summary}</p>
            <a class="service-card__link" href={service.href}>
              Otevřít sekci
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__header">
      <span class="section__eyebrow">Jak probíhá spolupráce</span>
      <h2 class="section__title">Od prvního hovoru po montáž</h2>
      <p class="section__intro">
        Web má být stejně přímý jako samotná spolupráce. Proto jsou tady hlavní kroky přehledně a bez
        zbytečných vrstev navíc.
      </p>
    </div>

    <div class="process-grid">
      {process.map((step, index) => (
        <article class="process-card">
          <div class="process-card__index">0{index + 1}</div>
          <h3>{step.title}</h3>
          <p>{step.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__header">
      <span class="section__eyebrow">Proč právě sem</span>
      <h2 class="section__title">Řemeslo, které stojí na osobním přístupu</h2>
    </div>

    <div class="process-grid">
      {strengths.map((item, index) => (
        <article class="process-card">
          <div class="process-card__index">0{index + 1}</div>
          <h3>{item}</h3>
          <p>
            Každá zakázka se řeší individuálně. Není to anonymní formulářový provoz, ale domluva s člověkem,
            který projekt opravdu vyrábí.
          </p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__header">
      <span class="section__eyebrow">Reference</span>
      <h2 class="section__title">Spokojenost zákazníků je nejlepší reklama</h2>
    </div>

    {references.map((reference) => (
      <article class="quote-card">
        <blockquote>{reference.quote}</blockquote>
        <footer>{reference.author}</footer>
      </article>
    ))}
  </section>

  <section class="section">
    <div class="section__header">
      <span class="section__eyebrow">Fotogalerie</span>
      <h2 class="section__title">Ukázka různých typů realizací</h2>
      <p class="section__intro">
        Místo těžké galerie s pluginy tady stačí rychlý, přehledný výběr obrázků, který se dobře načte i na
        mobilu.
      </p>
    </div>

    <div class="gallery-grid">
      {gallery.map((item) => (
        <figure class="gallery-card">
          <img src={item.src} alt={item.alt} loading="lazy" />
          <figcaption class="gallery-card__caption">{item.caption}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="contact-grid">
      <article class="contact-card contact-card--details">
        <span class="section__eyebrow">Kontakty</span>
        <h2>{company.owner}</h2>
        <p class="contact-subtitle">{company.addressName}</p>

        <div class="contact-stack">
          <div class="contact-block">
            <h3>Adresa:</h3>
            {company.addressLines.map((line) => (
              <p>{line}</p>
            ))}
          </div>

          <div class="contact-block">
            <h3>Fakturační údaje:</h3>
            <p>
              <strong>IČ:</strong> {company.ico}
            </p>
          </div>

          <div class="contact-block">
            <h3>Kontaktní informace:</h3>
            {company.phones.map((phone) => (
              <p>
                <strong>{phone.label}:</strong>{' '}
                <a href={`tel:+420${phone.href}`}>{phone.display}</a>
              </p>
            ))}
            <p>
              <strong>E-mail:</strong>{' '}
              <a href={`mailto:${company.email}`}>{company.email}</a>
            </p>
            <p>
              <strong>Facebook:</strong>{' '}
              <a href={company.facebook} target="_blank" rel="noreferrer">
                DR zámečnictví a kovovýroba
              </a>
            </p>
          </div>
        </div>
      </article>

      <article class="contact-card contact-card--map">
        <span class="section__eyebrow">Kde mě najdete</span>
        <div class="map-frame">
          <iframe
            title="Mapa - DR zámečnictví a kovovýroba"
            src={company.mapEmbedUrl}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
        <div class="contact-actions">
          <a
            class="button button--ghost"
            href={company.mapUrl}
            target="_blank"
            rel="noreferrer"
          >
            Otevřít mapu
          </a>
        </div>
      </article>
    </div>
  </section>
</Layout>
