---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Děkujeme | DR zámečnictví a kovovýroba" description="Formulář byl odeslán.">
  <section class="page-hero">
    <div class="section">
      <span class="eyebrow">Děkujeme</span>
      <h1>Formulář byl odeslán.</h1>
      <p>
        Vaše zpráva dorazila do systému. Pokud budete chtít něco doplnit, můžete kdykoliv zavolat nebo poslat další zprávu.
      </p>
      <div class="contact-actions">
        <a class="button button--primary" href="/kontakty">Kontakty</a>
        <a class="button button--ghost" href="/">Zpět na úvod</a>
      </div>
    </div>
  </section>
</Layout>
