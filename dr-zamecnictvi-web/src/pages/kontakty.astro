---
import Layout from '../layouts/Layout.astro';
import { company } from '../data/site';
---

<Layout
  title="Kontakty | DR zámečnictví a kovovýroba"
  description="Kontakt na Daniela Richtera, rodinnou dílnu ve Studénce a další možnosti spojení."
>
  <section class="page-hero">
    <div class="section">
      <span class="eyebrow">Kontakty</span>
      <h1>Domluvme si zakázku</h1>
      <p>
        Nejrychlejší je telefonát. Pokud už máte představu, můžeme rovnou probrat typ realizace, termín i
        místo zaměření.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="contact-grid">
      <article class="contact-card contact-card--details">
        <span class="section__eyebrow">Kontakty</span>
        <h2>{company.owner}</h2>
        <p class="contact-subtitle">{company.addressName}</p>

        <div class="contact-stack">
          <div class="contact-block">
            <h3>Adresa:</h3>
            {company.addressLines.map((line) => (
              <p>{line}</p>
            ))}
          </div>

          <div class="contact-block">
            <h3>Fakturační údaje:</h3>
            <p>
              <strong>IČ:</strong> {company.ico}
            </p>
          </div>

          <div class="contact-block">
            <h3>Kontaktní informace:</h3>
            {company.phones.map((phone) => (
              <p>
                <strong>{phone.label}:</strong>{' '}
                <a href={`tel:+420${phone.href}`}>{phone.display}</a>
              </p>
            ))}
            <p>
              <strong>E-mail:</strong>{' '}
              <a href={`mailto:${company.email}`}>{company.email}</a>
            </p>
            <p>
              <strong>Facebook:</strong>{' '}
              <a href={company.facebook} target="_blank" rel="noreferrer">
                DR zámečnictví a kovovýroba
              </a>
            </p>
          </div>
        </div>
      </article>

      <article class="contact-card contact-card--map">
        <span class="section__eyebrow">Kde mě najdete</span>
        <div class="map-frame">
          <iframe
            title="Mapa - DR zámečnictví a kovovýroba"
            src={company.mapEmbedUrl}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
        <div class="contact-actions">
          <a class="button button--ghost" href={company.mapUrl} target="_blank" rel="noreferrer">
            Otevřít mapu
          </a>
        </div>
      </article>
    </div>
  </section>
</Layout>
